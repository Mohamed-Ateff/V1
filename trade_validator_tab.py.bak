"""
Trade Validator — Cross-Engine Confluence Check
Validates your trade idea against every analytical engine in the app.
"""

import streamlit as st
import numpy as np
import pandas as pd

# ── Design tokens (match rest of app) ────────────────────────────────────────
BULL  = "#4caf50"
BEAR  = "#f44336"
NEUT  = "#ff9800"
INFO  = "#2196f3"
PURP  = "#9c27b0"
GOLD  = "#FFD700"
BG    = "#181818"
BG2   = "#212121"
BDR   = "#303030"


# ── UI helpers ────────────────────────────────────────────────────────────────
def _sec(title, color=INFO):
    return (
        f"<div style='font-size:1rem;color:#fff;font-weight:700;"
        f"margin:2rem 0 0.9rem 0;border-bottom:2px solid {color}33;"
        f"padding-bottom:0.5rem;'>{title}</div>"
    )


def _glowbar(pct, color=BULL, height="7px"):
    pct = max(0, min(100, float(pct)))
    return (
        f"<div style='background:{BDR};border-radius:999px;height:{height};overflow:hidden;'>"
        f"<div style='width:{pct}%;height:100%;"
        f"background:linear-gradient(90deg,{color}88,{color});border-radius:999px;'>"
        f"</div></div>"
    )


# ── Engine runner ─────────────────────────────────────────────────────────────
def _run_confluence(df, latest, current_price):
    """Run all analytical engines and return structured per-engine results."""
    results = {}
    cp = float(current_price)

    # ── Engine 1: AI Score (12 technical factors) ────────────────────────────
    try:
        from gemini_tab import _compute_ai_score, _decision_from_score
        score, _, _ = _compute_ai_score(latest, df, cp)
        decision, dec_col, dec_reason = _decision_from_score(score)

        if   score >= 65: ai_dir, ai_str = 'BUY',     'strong'
        elif score >= 52: ai_dir, ai_str = 'BUY',     'weak'
        elif score <= 35: ai_dir, ai_str = 'SELL',    'strong'
        elif score <= 48: ai_dir, ai_str = 'SELL',    'weak'
        else:             ai_dir, ai_str = 'NEUTRAL',  'none'

        results['ai_score'] = {
            'label':      'AI Score  (12 Factors)',
            'signal':     f"{decision} — {score}/100",
            'signal_col': dec_col,
            'direction':  ai_dir,
            'strength':   ai_str,
            'detail':     dec_reason,
            'weight':     25,
        }
    except Exception as e:
        results['ai_score'] = {
            'label': 'AI Score', 'signal': 'Error', 'direction': 'NEUTRAL',
            'strength': 'none', 'weight': 25, 'signal_col': '#555', 'detail': str(e),
        }

    # ── Engine 2: ML Ensemble (5-model, 10-day) ──────────────────────────────
    try:
        from gemini_tab import _ml_predict
        ml = _ml_predict(df, horizon=10)
        if ml:
            prob = ml['up_prob']
            if   prob >= 60: ml_dir, ml_str = 'BUY',     'strong'
            elif prob >= 55: ml_dir, ml_str = 'BUY',     'weak'
            elif prob <= 40: ml_dir, ml_str = 'SELL',    'strong'
            elif prob <= 45: ml_dir, ml_str = 'SELL',    'weak'
            else:            ml_dir, ml_str = 'NEUTRAL',  'none'

            results['ml'] = {
                'label':      'ML Ensemble  (5 Models · 10-Day)',
                'signal':     f"{prob:.0f}% chance UP",
                'signal_col': BULL if prob >= 55 else (BEAR if prob <= 45 else NEUT),
                'direction':  ml_dir,
                'strength':   ml_str,
                'detail':     f"{ml['model_name']} · {ml['n_features']} features · {ml['cv_folds']}-fold CV",
                'weight':     25,
            }
        else:
            results['ml'] = {
                'label': 'ML Ensemble', 'signal': 'Insufficient data', 'direction': 'NEUTRAL',
                'strength': 'none', 'weight': 25, 'signal_col': '#555', 'detail': 'Need ≥60 bars',
            }
    except Exception as e:
        results['ml'] = {
            'label': 'ML Ensemble', 'signal': 'Error', 'direction': 'NEUTRAL',
            'strength': 'none', 'weight': 25, 'signal_col': '#555', 'detail': str(e),
        }

    # ── Engine 3: Historical Analogues (KNN, 10-day) ─────────────────────────
    try:
        from gemini_tab import _historical_analogy
        ana = _historical_analogy(df, k=25, horizon=10)
        if ana:
            wr = ana['w_win_rate']
            if   wr >= 62: ana_dir, ana_str = 'BUY',     'strong'
            elif wr >= 55: ana_dir, ana_str = 'BUY',     'weak'
            elif wr <= 38: ana_dir, ana_str = 'SELL',    'strong'
            elif wr <= 45: ana_dir, ana_str = 'SELL',    'weak'
            else:          ana_dir, ana_str = 'NEUTRAL',  'none'

            results['historical'] = {
                'label':      'Historical Analogues  (KNN · 25 setups)',
                'signal':     f"{wr:.0f}% win rate  ({ana['n_up']}↑ / {ana['n_down']}↓ of {ana['n_similar']})",
                'signal_col': BULL if wr >= 55 else (BEAR if wr <= 45 else NEUT),
                'direction':  ana_dir,
                'strength':   ana_str,
                'detail':     (f"Median: {ana['median_return']:+.1f}%  |  "
                               f"Best: +{ana['best_case']:.1f}%  |  "
                               f"Worst: {ana['worst_case']:.1f}%"),
                'weight':     20,
            }
        else:
            results['historical'] = {
                'label': 'Historical Analogues', 'signal': 'No data', 'direction': 'NEUTRAL',
                'strength': 'none', 'weight': 20, 'signal_col': '#555', 'detail': 'Insufficient history',
            }
    except Exception as e:
        results['historical'] = {
            'label': 'Historical Analogues', 'signal': 'Error', 'direction': 'NEUTRAL',
            'strength': 'none', 'weight': 20, 'signal_col': '#555', 'detail': str(e),
        }

    # ── Engine 4: SMC Bias + Engine 5: Market Structure ──────────────────────
    try:
        from smc_tab import (
            _find_swing_points, _market_structure, _liquidity_zones,
            _detect_sweeps, _detect_choch_bos, _find_order_block,
            _find_fvgs, _build_trade_plan,
        )

        df_s = df.copy()
        if "Date" not in df_s.columns:
            df_s = df_s.reset_index()
            if "index" in df_s.columns:
                df_s.rename(columns={"index": "Date"}, inplace=True)
        df_s["Date"] = pd.to_datetime(df_s["Date"])

        sh, sl = _find_swing_points(df_s)
        if len(sh) < 2:
            sh = list(range(0, len(df_s) - 1, max(1, len(df_s) // 8)))
        if len(sl) < 2:
            sl = list(range(0, len(df_s) - 1, max(1, len(df_s) // 8)))

        trend, sh_p, sl_p = _market_structure(df_s, sh, sl)
        bsl, ssl, mh, ml2 = _liquidity_zones(df_s, sh, sl)
        sweep  = _detect_sweeps(df_s, bsl, ssl, mh, ml2)
        choch  = _detect_choch_bos(df_s, sh, sl, trend)
        ob     = _find_order_block(df_s, sh, sl, trend, choch)
        fvg    = _find_fvgs(df_s)
        plan   = _build_trade_plan(df_s, cp, trend, sweep, choch, ob, fvg, bsl, ssl, mh, ml2)

        smc_bias = plan['bias']
        smc_conf = plan['confidence']
        if   smc_bias == 'BUY':  smc_dir, smc_str = 'BUY',     'strong' if smc_conf >= 65 else 'weak'
        elif smc_bias == 'SELL': smc_dir, smc_str = 'SELL',    'strong' if smc_conf >= 65 else 'weak'
        else:                    smc_dir, smc_str = 'NEUTRAL',  'none'

        choch_str = f"{choch['type']} {choch['direction'][:4]}" if choch else 'None'
        ob_str    = ob['direction'] if ob else 'None'

        results['smc'] = {
            'label':      'SMC Analysis',
            'signal':     f"{smc_bias}  —  {smc_conf}% confidence",
            'signal_col': plan['bias_color'],
            'direction':  smc_dir,
            'strength':   smc_str,
            'detail':     f"Score: {plan['score']:+d}  |  CHoCH/BOS: {choch_str}  |  OB: {ob_str}",
            'weight':     20,
        }

        if   trend == 'UPTREND':   tr_dir, tr_str = 'BUY',  'strong'
        elif trend == 'DOWNTREND': tr_dir, tr_str = 'SELL', 'strong'
        else:                      tr_dir, tr_str = 'NEUTRAL', 'none'

        tr_color = BULL if trend == 'UPTREND' else (BEAR if trend == 'DOWNTREND' else NEUT)
        sh_txt = (f"SH: {sh_p[-2][1]:.2f} \u2192 {sh_p[-1][1]:.2f}"
                  if len(sh_p) >= 2 else 'Insufficient swings')

        results['structure'] = {
            'label':      'Market Structure',
            'signal':     trend,
            'signal_col': tr_color,
            'direction':  tr_dir,
            'strength':   tr_str,
            'detail':     sh_txt,
            'weight':     10,
        }

    except Exception as e:
        results['smc'] = {
            'label': 'SMC Analysis', 'signal': 'Error', 'direction': 'NEUTRAL',
            'strength': 'none', 'weight': 20, 'signal_col': '#555', 'detail': str(e),
        }
        results['structure'] = {
            'label': 'Market Structure', 'signal': 'Error', 'direction': 'NEUTRAL',
            'strength': 'none', 'weight': 10, 'signal_col': '#555', 'detail': '',
        }

    return results


def _score_confluence(results, direction):
    """
    Score each engine's agreement with the proposed trade direction.
    Strong agree/conflict → ±1.0  |  Weak → ±0.6  |  Neutral → 0.
    Returns (confluence_score 0-100, verdicts dict).
    """
    verdicts     = {}
    total_weight = 0
    weighted_sum = 0.0

    for key, eng in results.items():
        eng_dir  = eng['direction']
        strength = eng.get('strength', 'none')
        weight   = eng['weight']
        total_weight += weight

        if eng_dir == 'NEUTRAL':
            raw, verdict = 0.0, 'neutral'
        elif eng_dir == direction:
            raw     = 1.0 if strength == 'strong' else 0.6
            verdict = 'agree'
        else:
            raw     = -1.0 if strength == 'strong' else -0.6
            verdict = 'conflict'

        weighted_sum += raw * weight
        verdicts[key] = {**eng, 'verdict': verdict, 'raw_score': raw}

    # Normalize [-total_weight, +total_weight] → [0, 100]
    if total_weight > 0:
        norm = (weighted_sum / total_weight + 1.0) / 2.0 * 100
    else:
        norm = 50.0

    return round(norm, 1), verdicts


# ── Main render ───────────────────────────────────────────────────────────────
def trade_validator_tab(df, latest, current_price):
    """Entry point called from app.py"""

    if df is None or len(df) < 30:
        st.warning("Not enough data. Need at least 30 bars.")
        return
    if hasattr(latest, 'to_dict'):
        latest = latest.to_dict()

    cp = float(current_price)
    try:
        atr14 = float((df["High"] - df["Low"]).tail(14).mean())
    except Exception:
        atr14 = cp * 0.01

    # ── INPUT FORM (st.form avoids re-run on every widget change) ─────────────
    st.markdown(_sec("Your Trade Idea", PURP), unsafe_allow_html=True)

    with st.form("tv_form"):
        col_dir, col_entry, col_sl, col_tp, col_port, col_risk = st.columns(
            [0.8, 1, 1, 1, 1.2, 0.8], gap="small"
        )
        with col_dir:
            direction = st.selectbox("Direction", ["BUY", "SELL"])
        with col_entry:
            entry_p = st.number_input("Entry Price",
                                       value=round(cp, 2),
                                       min_value=0.01, format="%.2f")
        with col_sl:
            stop_p = st.number_input("Stop Loss",
                                      value=round(cp - atr14 * 1.5, 2),
                                      min_value=0.01, format="%.2f")
        with col_tp:
            target_p = st.number_input("Take Profit",
                                        value=round(cp + atr14 * 3.0, 2),
                                        min_value=0.01, format="%.2f")
        with col_port:
            portfolio = st.number_input("Portfolio (SAR)",
                                         value=100000, min_value=1000, step=5000)
        with col_risk:
            max_risk_pct = st.number_input("Risk %",
                                            value=1.0, min_value=0.1,
                                            max_value=10.0, step=0.1, format="%.1f")

        submitted = st.form_submit_button("🔍  Validate Trade",
                                           type="primary", use_container_width=True)

    # ── PLACEHOLDER (before first submit) ─────────────────────────────────────
    if not submitted and 'tv_results' not in st.session_state:
        st.markdown(
            f"<div style='margin-top:2.5rem;padding:2.5rem;background:{BG2};"
            f"border:1px solid {BDR};border-radius:16px;text-align:center;'>"
            f"<div style='font-size:2rem;margin-bottom:0.6rem;'>&#128269;</div>"
            f"<div style='color:#777;font-size:0.9rem;line-height:1.6;'>"
            f"Set your parameters above and click <b style='color:#fff;'>Validate Trade</b>.<br>"
            f"<span style='font-size:0.75rem;color:#555;'>"
            f"AI Score &middot; ML Ensemble &middot; Historical Analogues "
            f"&middot; SMC &middot; Market Structure</span>"
            f"</div></div>",
            unsafe_allow_html=True,
        )
        return

    # ── RUN ENGINES on submit ─────────────────────────────────────────────────
    if submitted:
        with st.spinner("Running all engines… (first run may take 20-40s)"):
            try:
                results = _run_confluence(df, latest, cp)
                confluence_score, verdicts = _score_confluence(results, direction)
                st.session_state['tv_results'] = {
                    'results':          results,
                    'confluence_score': confluence_score,
                    'verdicts':         verdicts,
                    'direction':        direction,
                    'entry_p':          float(entry_p),
                    'stop_p':           float(stop_p),
                    'target_p':         float(target_p),
                    'portfolio':        float(portfolio),
                    'max_risk_pct':     float(max_risk_pct),
                }
            except Exception as e:
                import traceback
                st.error(f"Engine error — {e}")
                st.code(traceback.format_exc())
                return

    if 'tv_results' not in st.session_state:
        return

    # ── LOAD SAVED RESULTS ────────────────────────────────────────────────────
    r                = st.session_state['tv_results']
    results          = r['results']
    confluence_score = r['confluence_score']
    verdicts         = r['verdicts']
    direction        = r['direction']
    entry_p          = r['entry_p']
    stop_p           = r['stop_p']
    target_p         = r['target_p']
    portfolio        = r['portfolio']
    max_risk_pct     = r['max_risk_pct']

    # ── TRADE METRICS ─────────────────────────────────────────────────────────
    risk_per_share   = abs(entry_p - stop_p)
    reward_per_share = abs(target_p - entry_p)
    rr           = reward_per_share / risk_per_share if risk_per_share > 0 else 0.0
    sl_pct       = (stop_p  / entry_p - 1) * 100 if entry_p > 0 else 0.0
    tp_pct       = (target_p / entry_p - 1) * 100 if entry_p > 0 else 0.0
    risk_sar     = portfolio * (max_risk_pct / 100)
    shares       = int(risk_sar / risk_per_share) if risk_per_share > 0 else 0
    position_sar = shares * entry_p

    agree_count    = sum(1 for v in verdicts.values() if v['verdict'] == 'agree')
    conflict_count = sum(1 for v in verdicts.values() if v['verdict'] == 'conflict')
    neutral_count  = sum(1 for v in verdicts.values() if v['verdict'] == 'neutral')
    n_engines      = len(verdicts)

    if   confluence_score >= 70: fv_txt, fv_col, fv_icon = 'GO',     BULL, '&#10003;'
    elif confluence_score >= 50: fv_txt, fv_col, fv_icon = 'REVIEW', NEUT, '&#9888;'
    else:                        fv_txt, fv_col, fv_icon = 'NO-GO',  BEAR, '&#10007;'

    cs_col  = BULL if confluence_score >= 70 else (BEAR if confluence_score < 45 else NEUT)
    dir_col = BULL if direction == 'BUY' else BEAR

    # ── VERDICT HERO ─────────────────────────────────────────────────────────
    st.markdown(_sec("Cross-Engine Confluence Check", INFO), unsafe_allow_html=True)

    st.markdown(
        f"<div style='background:{BG2};border:1px solid {fv_col}44;"
        f"border-left:6px solid {fv_col};border-radius:16px;"
        f"padding:1.6rem 2rem;margin-bottom:1.2rem;'>"
        f"<div style='display:flex;align-items:center;"
        f"justify-content:space-between;gap:2rem;flex-wrap:wrap;'>"
        f"<div>"
        f"<div style='font-size:0.6rem;color:#9e9e9e;text-transform:uppercase;"
        f"letter-spacing:1.5px;font-weight:700;margin-bottom:0.5rem;'>"
        f"<span style='color:{dir_col};'>{direction}</span>"
        f" &nbsp;&middot;&nbsp; Entry {entry_p:.2f}"
        f" &nbsp;&middot;&nbsp; SL {stop_p:.2f}"
        f" &nbsp;&middot;&nbsp; TP {target_p:.2f}"
        f" &nbsp;&middot;&nbsp; R:R 1:{rr:.2f}</div>"
        f"<div style='font-size:3rem;font-weight:900;color:{fv_col};"
        f"line-height:1;letter-spacing:2px;'>{fv_icon} {fv_txt}</div>"
        f"<div style='font-size:0.8rem;color:#aaa;margin-top:0.5rem;'>"
        f"<b style='color:{BULL};'>{agree_count}</b> engines agree"
        f" &nbsp;&middot;&nbsp; "
        f"<b style='color:{BEAR};'>{conflict_count}</b> conflict"
        f" &nbsp;&middot;&nbsp; "
        f"<b style='color:#555;'>{neutral_count}</b> neutral"
        f"</div></div>"
        f"<div style='text-align:center;min-width:120px;'>"
        f"<div style='font-size:0.58rem;color:#9e9e9e;text-transform:uppercase;"
        f"letter-spacing:1px;font-weight:700;margin-bottom:0.3rem;'>Confluence</div>"
        f"<div style='font-size:3.8rem;font-weight:900;color:{cs_col};"
        f"line-height:1;'>{confluence_score:.0f}%</div>"
        + _glowbar(confluence_score, cs_col, "8px") +
        f"</div></div></div>",
        unsafe_allow_html=True,
    )

    # ── PER-ENGINE ROWS ───────────────────────────────────────────────────────
    for key in ['ai_score', 'ml', 'historical', 'smc', 'structure']:
        if key not in verdicts:
            continue
        v       = verdicts[key]
        verdict = v['verdict']
        if   verdict == 'agree':    v_icon, v_color, v_lbl = '&#10003;', BULL, 'AGREES'
        elif verdict == 'conflict': v_icon, v_color, v_lbl = '&#10007;', BEAR, 'CONFLICTS'
        else:                       v_icon, v_color, v_lbl = '&mdash;',  '#555', 'NEUTRAL'

        st.markdown(
            f"<div style='background:{BG2};border:1px solid {BDR};"
            f"border-left:4px solid {v_color};border-radius:12px;"
            f"padding:0.75rem 1.2rem;margin-bottom:0.45rem;"
            f"display:flex;align-items:center;justify-content:space-between;gap:1rem;'>"
            f"<div style='width:2rem;height:2rem;border-radius:50%;"
            f"background:{v_color}22;border:2px solid {v_color};"
            f"display:flex;align-items:center;justify-content:center;"
            f"font-size:0.9rem;font-weight:900;color:{v_color};flex-shrink:0;'>"
            f"{v_icon}</div>"
            f"<div style='flex:1;min-width:0;'>"
            f"<div style='font-size:0.82rem;font-weight:800;color:#fff;'>{v['label']}</div>"
            f"<div style='font-size:0.67rem;color:#666;margin-top:0.1rem;"
            f"white-space:nowrap;overflow:hidden;text-overflow:ellipsis;'>"
            f"{v.get('detail', '')}</div></div>"
            f"<div style='text-align:center;min-width:160px;'>"
            f"<div style='font-size:0.55rem;color:#9e9e9e;text-transform:uppercase;"
            f"letter-spacing:0.5px;margin-bottom:0.1rem;'>Signal</div>"
            f"<div style='font-size:0.82rem;font-weight:800;"
            f"color:{v.get('signal_col','#fff')};'>{v.get('signal','&mdash;')}</div></div>"
            f"<div style='text-align:right;min-width:100px;'>"
            f"<div style='background:{v_color}18;border:1.5px solid {v_color};"
            f"border-radius:8px;padding:0.18rem 0.8rem;display:inline-block;"
            f"font-size:0.75rem;font-weight:800;color:{v_color};'>{v_lbl}</div>"
            f"<div style='font-size:0.58rem;color:#444;margin-top:0.22rem;'>"
            f"{v['weight']}% weight</div></div>"
            f"</div>",
            unsafe_allow_html=True,
        )

    # ── QUALITY CHECKLIST + POSITION SIZING ──────────────────────────────────
    st.markdown(_sec("Quality Checklist &amp; Position Sizing", PURP),
                unsafe_allow_html=True)
    chk_col, pos_col = st.columns(2, gap="medium")

    with chk_col:
        checks = [
            ("R:R ≥ 2 : 1",             rr >= 2.0,                        f"1:{rr:.2f}"),
            ("Confluence ≥ 70%",         confluence_score >= 70,           f"{confluence_score:.0f}%"),
            ("≥ 3 of 5 engines agree",   agree_count >= 3,                 f"{agree_count}/{n_engines}"),
            ("Stop risk ≤ 3% from entry",abs(sl_pct) <= 3.0,              f"{abs(sl_pct):.2f}%"),
            ("Target move ≥ 0.5%",       abs(tp_pct) >= 0.5,              f"{abs(tp_pct):.1f}%"),
            ("Position ≤ 40% portfolio", position_sar <= portfolio * 0.40, f"{position_sar/max(portfolio,1)*100:.0f}%"),
        ]
        passed    = sum(1 for _, ok, _ in checks if ok)
        chk_color = BULL if passed >= 5 else (NEUT if passed >= 3 else BEAR)

        rows_html = "".join(
            f"<div style='display:flex;justify-content:space-between;align-items:center;"
            f"padding:0.45rem 0.8rem;"
            f"border-left:3px solid {BULL if ok else BEAR};"
            f"background:{BULL if ok else BEAR}08;"
            f"border-radius:0 8px 8px 0;margin-bottom:0.22rem;'>"
            f"<div style='display:flex;align-items:center;gap:0.5rem;'>"
            f"<span style='font-weight:900;color:{BULL if ok else BEAR};"
            f"font-size:0.85rem;'>{'&#10003;' if ok else '&#10007;'}</span>"
            f"<span style='font-size:0.73rem;color:#ccc;font-weight:600;'>{lbl}</span>"
            f"</div>"
            f"<span style='font-size:0.7rem;color:#666;'>{note}</span>"
            f"</div>"
            for lbl, ok, note in checks
        )

        st.markdown(
            f"<div style='background:{BG2};border:1px solid {BDR};"
            f"border-top:3px solid {chk_color};border-radius:14px;padding:1rem;'>"
            f"<div style='display:flex;justify-content:space-between;align-items:center;"
            f"margin-bottom:0.7rem;'>"
            f"<div style='font-size:0.58rem;color:#9e9e9e;text-transform:uppercase;"
            f"letter-spacing:1.2px;font-weight:700;'>Quality Gates</div>"
            f"<div style='font-size:0.9rem;font-weight:900;color:{chk_color};'>"
            f"{passed}/{len(checks)} passed</div></div>"
            f"{rows_html}</div>",
            unsafe_allow_html=True,
        )

    with pos_col:
        port_pct = position_sar / max(portfolio, 1) * 100
        pp_col   = BULL if port_pct <= 25 else (NEUT if port_pct <= 40 else BEAR)

        def _r(lbl, val, col="#fff", big=False):
            fs = "1.2rem" if big else "0.88rem"
            return (
                f"<div style='display:flex;justify-content:space-between;"
                f"align-items:center;padding:0.45rem 0;border-bottom:1px solid {BDR};'>"
                f"<span style='font-size:0.7rem;color:#666;'>{lbl}</span>"
                f"<span style='font-size:{fs};font-weight:900;color:{col};'>{val}</span>"
                f"</div>"
            )

        st.markdown(
            f"<div style='background:{BG2};border:1px solid {BDR};"
            f"border-top:3px solid {INFO};border-radius:14px;padding:1.1rem 1.2rem;'>"
            f"<div style='font-size:0.58rem;color:#9e9e9e;text-transform:uppercase;"
            f"letter-spacing:1.2px;font-weight:700;margin-bottom:0.8rem;'>Position Sizing</div>"
            + _r("Shares to trade",       f"{shares:,}",           "#fff", big=True)
            + _r("Position value (SAR)",  f"{position_sar:,.0f}",  pp_col)
            + _r("% of portfolio",        f"{port_pct:.0f}%",      pp_col)
            + _r("Max risk (SAR)",        f"{risk_sar:,.0f}",      BEAR)
            + _r("Risk per share",        f"{risk_per_share:.2f}", BEAR)
            + _r("R : R",                 f"1:{rr:.2f}",           BULL if rr >= 2 else NEUT)
            + f"<div style='display:grid;grid-template-columns:1fr 1fr;gap:0.5rem;margin-top:0.8rem;'>"
            + f"<div style='background:{BEAR}15;border:1px solid {BEAR}33;"
              f"border-radius:10px;padding:0.6rem;text-align:center;'>"
              f"<div style='font-size:0.52rem;color:#9e9e9e;margin-bottom:0.1rem;'>STOP LOSS</div>"
              f"<div style='font-size:1.1rem;font-weight:900;color:{BEAR};'>{sl_pct:.1f}%</div>"
              f"<div style='font-size:0.62rem;color:#555;'>{stop_p:.2f}</div></div>"
            + f"<div style='background:{BULL}15;border:1px solid {BULL}33;"
              f"border-radius:10px;padding:0.6rem;text-align:center;'>"
              f"<div style='font-size:0.52rem;color:#9e9e9e;margin-bottom:0.1rem;'>TARGET</div>"
              f"<div style='font-size:1.1rem;font-weight:900;color:{BULL};'>+{abs(tp_pct):.1f}%</div>"
              f"<div style='font-size:0.62rem;color:#555;'>{target_p:.2f}</div></div>"
            + f"</div></div>",
            unsafe_allow_html=True,
        )

    st.markdown(
        f"<div style='margin-top:1.5rem;padding:0.6rem 1rem;background:{BG2};"
        f"border:1px solid {BDR};border-radius:10px;font-size:0.6rem;color:#444;'>"
        f"For informational purposes only. Statistical patterns — not guaranteed outcomes."
        f"</div>",
        unsafe_allow_html=True,
    )
